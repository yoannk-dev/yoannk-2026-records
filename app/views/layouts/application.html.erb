<!DOCTYPE html>
<html lang="en" data-theme="light" data-controller="theme">
  <head>
    <title>Vinyle — Collection</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="panel">
    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <%= yield %>

    <div id="scrim" class="scrim"
         data-panel-target="scrim"
         data-action="click->panel#close"></div>

    <aside id="panel" class="panel" data-panel-target="panel">
      <turbo-frame id="panel_content"></turbo-frame>
    </aside>
  </body>
</html>
