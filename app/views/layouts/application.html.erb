<!DOCTYPE html>
<html lang="en" data-theme="light" data-controller="theme">
  <head>
    <title>Vinyles — Collection</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="panel<%= user_signed_in? ? ' scanner' : '' %>"
        <% if user_signed_in? %>data-scanner-lookup-url-value="<%= records_discogs_lookup_path %>"
        data-scanner-tracklist-url-value="<%= records_discogs_tracklist_path %>"<% end %>>
    <%= render "layouts/flash" %>
    <%= yield %>
    <%= render "layouts/panel" %>
    <% if user_signed_in? %>
      <button class="btn btn--primary btn--fab" data-action="scanner#open" aria-label="Add new record">
        <svg width="14" height="14" viewBox="0 0 14 14">
          <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="scanner" data-scanner-target="overlay">
        <div class="scanner__header">
          <div class="scanner__mode-tabs">
            <button class="scanner__mode-tab is-active"
                    data-scanner-target="barcodeTab"
                    data-action="scanner#switchMode"
                    data-mode="barcode">Barcode</button>
            <button class="scanner__mode-tab"
                    data-scanner-target="catnoTab"
                    data-action="scanner#switchMode"
                    data-mode="catno">Catalog #</button>
          </div>
          <button class="icon-btn scanner__close-btn"
                  data-action="scanner#close"
                  aria-label="Close scanner">
            <svg width="14" height="14" viewBox="0 0 14 14">
              <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="scanner__body">
          <div class="scanner__viewfinder">
            <video class="scanner__video"
                   data-scanner-target="video"
                   autoplay
                   playsinline
                   muted></video>
            <div class="scanner__reticle"></div>
          </div>

          <p class="scanner__status" data-scanner-target="status"></p>

          <button class="btn btn--ghost scanner-manual-toggle u-hidden"
                  data-scanner-target="manualBtn"
                  data-action="scanner#showManual">
            Ajout manuel
          </button>

          <form class="scanner__manual u-hidden"
                data-scanner-target="manualForm"
                data-action="submit->scanner#submitManual">
            <div class="form-field">
              <label for="scanner-manual-input">Référence</label>
              <input id="scanner-manual-input"
                     type="text"
                     inputmode="numeric"
                     placeholder="ex : 0602435688435"
                     data-scanner-target="manualInput">
            </div>
            <button type="submit" class="btn btn--primary">Rechercher</button>
          </form>

          <button class="btn btn--ghost u-hidden"
                  data-scanner-target="retryBtn"
                  data-action="scanner#retry">
            Retry
          </button>
        </div>
      </div>
    <% end %>
  </body>
</html>
