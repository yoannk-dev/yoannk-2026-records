<!DOCTYPE html>
<html lang="en" data-theme="light" data-controller="theme">
  <head>
    <title>Vinyles — Collection</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="panel<%= user_signed_in? ? ' scanner' : '' %>"
        <% if user_signed_in? %>data-scanner-lookup-url-value="<%= records_discogs_lookup_path %>"
        data-scanner-tracklist-url-value="<%= records_discogs_tracklist_path %>"<% end %>>
    <%= render "layouts/flash" %>
    <%= yield %>
    <%= render "layouts/panel" %>
    <% if user_signed_in? %>
      <div class="scanner-overlay" data-scanner-target="overlay">
        <div class="scanner-header">
          <span class="scanner-title">Scan Barcode</span>
          <button class="icon-btn scanner-close-btn"
                  data-action="scanner#close"
                  aria-label="Close scanner">
            <svg width="14" height="14" viewBox="0 0 14 14">
              <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="scanner-body">
          <div class="scanner-viewfinder">
            <video class="scanner-video"
                   data-scanner-target="video"
                   autoplay
                   playsinline
                   muted></video>
            <div class="scanner-reticle"></div>
          </div>

          <p class="scanner-status" data-scanner-target="status"></p>

          <form class="scanner-manual hidden"
                data-scanner-target="manualForm"
                data-action="submit->scanner#submitManual">
            <div class="form-field">
              <label for="scanner-barcode-input">Barcode</label>
              <input id="scanner-barcode-input"
                     type="text"
                     inputmode="numeric"
                     pattern="[0-9]*"
                     placeholder="e.g. 0602435688435"
                     data-scanner-target="manualInput">
            </div>
            <button type="submit" class="btn btn-primary">Look up</button>
          </form>

          <button class="btn btn-ghost hidden"
                  data-scanner-target="retryBtn"
                  data-action="scanner#retry">
            Retry
          </button>
        </div>
      </div>
    <% end %>
  </body>
</html>
