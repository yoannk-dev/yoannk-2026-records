<!DOCTYPE html>
<html lang="fr" data-theme="light" data-controller="theme">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "Vinyles — Collection" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="panel<%= ' scanner' if user_signed_in? %>"
        <% if user_signed_in? %>
          data-scanner-lookup-url-value="<%= records_discogs_lookup_path %>"
          data-scanner-tracklist-url-value="<%= records_discogs_tracklist_path %>"
        <% end %>>
    <div class="verbatim" role="banner" aria-label="Site description">
      A personal vinyl record collection tracker by <strong><a href="https://yoann-k.com" target="_blank">yoann-k</a></strong>. Each record is imported via Discogs API by scanning the barcode or by catalog number.
    </div>
    <%= render "layouts/flash" %>
    <%= yield %>
    <%= render "layouts/panel" %>
    <%= render "layouts/scanner" if user_signed_in? %>
  </body>
</html>
