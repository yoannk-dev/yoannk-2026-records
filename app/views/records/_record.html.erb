<div class="cell" id="record_<%= record.id %>">
  <%= link_to record_path(record),
        class: "cell__btn",
        data: {
          turbo_frame: "panel_content",
          action: "panel#open"
        },
        aria: { label: "#{record.artist} — #{record.title}" } do %>
    <%= render "sleeve", record: record %>
  <% end %>
  <div class="cell__caption">
    <div class="cell__caption-artist"><%= record.artist %></div>
    <div class="cell__caption-title"><%= record.title %></div>
  </div>
</div>
