<%# locals: (genres:, genre:) %>
<header class="topbar" data-controller="filter" data-filter-genre-value="<%= genre %>">
  <nav class="filters" aria-label="Filter by genre">
    <%= link_to "All", root_path,
          class: "chip #{'chip-active' if genre.blank?}",
          data: { turbo_action: "replace" } %>
    <% genres.each do |g| %>
      <%= link_to g, root_path(genre: g),
            class: "chip #{'chip-active' if genre == g}",
            data: { turbo_action: "replace" } %>
    <% end %>
  </nav>

  <div class="topbar-actions">
    <button class="icon-btn"
            data-action="theme#toggle"
            aria-label="Toggle theme"
            title="Toggle theme">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
        <path d="M13.8 9.6A6 6 0 1 1 6.4 2.2a4.8 4.8 0 0 0 7.4 7.4Z"
              stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      </svg>
    </button>

    <% if user_signed_in? %>
      <div data-controller="scanner"
           data-scanner-lookup-url-value="<%= records_discogs_lookup_path %>">
        <button class="btn btn-primary" data-action="scanner#open">
          <svg width="13" height="13" viewBox="0 0 14 14" style="margin-right:7px">
            <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          Add new
        </button>

        <div class="scanner-overlay" data-scanner-target="overlay">
          <div class="scanner-header">
            <span class="scanner-title">Scan Barcode</span>
            <button class="icon-btn scanner-close-btn"
                    data-action="scanner#close"
                    aria-label="Close scanner">
              <svg width="14" height="14" viewBox="0 0 14 14">
                <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </button>
          </div>

          <div class="scanner-body">
            <div class="scanner-viewfinder">
              <video class="scanner-video"
                     data-scanner-target="video"
                     autoplay
                     playsinline
                     muted></video>
              <div class="scanner-reticle"></div>
            </div>

            <p class="scanner-status" data-scanner-target="status"></p>

            <form class="scanner-manual hidden"
                  data-scanner-target="manualForm"
                  data-action="submit->scanner#submitManual">
              <div class="form-field">
                <label for="scanner-barcode-input">Barcode</label>
                <input id="scanner-barcode-input"
                       type="text"
                       inputmode="numeric"
                       pattern="[0-9]*"
                       placeholder="e.g. 0602435688435"
                       data-scanner-target="manualInput">
              </div>
              <button type="submit" class="btn btn-primary">Look up</button>
            </form>

            <button class="btn btn-ghost hidden"
                    data-scanner-target="retryBtn"
                    data-action="scanner#retry">
              Retry
            </button>
          </div>
        </div>
      </div>
    <% else %>
      <div class="add-prompt-wrap"
           data-controller="add-prompt"
           data-add-prompt-logged-in-value="false">
        <button class="btn btn-primary"
                data-action="add-prompt#open">
          <svg width="13" height="13" viewBox="0 0 14 14" style="margin-right:7px">
            <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          Add new
        </button>
      </div>
    <% end %>
  </div>
</header>
