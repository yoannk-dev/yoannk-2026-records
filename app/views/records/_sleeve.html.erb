<%# locals: (record:, radius: nil, size: nil) %>
<% style = "" %>
<% style += "border-radius:#{radius}px;" if radius %>
<% style += "width:#{size}px;height:#{size}px;" if size %>

<div class="sleeve" style="<%= style %>">
  <img src="<%= record.cover_image_url %>"
       alt="<%= record.artist %> – <%= record.title %>"
       style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover">
</div>
