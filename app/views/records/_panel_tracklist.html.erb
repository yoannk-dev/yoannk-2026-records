<%# locals: (record:) %>
<% tl = record.tracklist %>
<% if tl.is_a?(Array)
     tl = tl.each_with_object({}) do |t, sides|
       side = t["position"].to_s.match(/\A([a-z])/i)&.[](1)&.downcase || "a"
       (sides[side] ||= []) << t["title"].to_s
     end
   end %>
<% all_tracks = tl&.sort&.flat_map(&:last) || [] %>
<% if all_tracks.any? %>
  <div class="tracklist">
    <div class="side-label">Tracklist</div>
    <ol>
      <% all_tracks.each do |track| %>
        <li><%= track %></li>
      <% end %>
    </ol>
  </div>
<% end %>
