<div class="app">
  <%= render "masthead" %>
  <%= render "topbar", genres: @genres, genre: @genre %>

  <main class="grid" id="records-grid">
    <%= render partial: "record", collection: @records, as: :record %>
  </main>

  <% if @records.empty? %>
    <div class="empty">
      <%= @genre.present? ? "Nothing in #{@genre} yet." : "No records in the collection yet." %>
    </div>
  <% end %>

  <% if @has_more %>
    <div data-controller="infinite-scroll"
         data-infinite-scroll-url-value="<%= root_path(page: @page + 1, genre: @genre) %>">
    </div>
  <% end %>
</div>
